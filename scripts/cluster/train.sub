# HTCondor submit template for probe training.
# Per-model overrides (arguments, request_gpus, output/error/log) are supplied
# via -append from submit_all_train.sh, so this file holds only the static parts.
executable      = /bin/bash
request_cpus    = 16
request_memory  = 131072
request_gpus    = 1
requirements    = TARGET.CUDADeviceName == "NVIDIA H100 80GB HBM3"
request_disk    = 400G
+BypassLXCfs    = "true"
queue
