# HTCondor submit template for cross-model rollouts + ground truth.
# Pure API work (OpenRouter + Anthropic over the node HTTP proxy) — NO GPU.
# Per-model overrides (arguments, output/error/log) come via -append.
executable      = /bin/bash
request_cpus    = 8
request_memory  = 32768
request_disk    = 50G
+BypassLXCfs    = "true"
queue
